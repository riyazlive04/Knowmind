# Prisma / Neon Postgres connection.
#   DATABASE_URL: POOLED connection (host contains "-pooler") — app runtime.
#   DIRECT_URL:   DIRECT connection (no "-pooler")           — migrations.
# Get both from Neon → Connect → toggle "Connection pooling" on/off. Drop any
# "&channel_binding=require" from the string; keep "?sslmode=require".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Console admin seeded by `npm run db:seed`.
ADMIN_EMAIL="admin@knowmind.in"
ADMIN_PASSWORD="choose-a-strong-password"
