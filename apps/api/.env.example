PORT=4000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Evolution WhatsApp API (M5). Leave EVOLUTION_* empty to stub sends in dev
# (status: queued, no network). Point the URL at the API base, NOT the /manager UI.
EVOLUTION_API_URL=https://your-evolution-host
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=your-instance-name

# Staggered bulk send — randomized gap (ms) between each WhatsApp message.
DELIVERY_MIN_INTERVAL_MS=30000
DELIVERY_MAX_INTERVAL_MS=90000

# Server-to-server auth for delivery routes (must match apps/web BACKEND_API_TOKEN).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
BACKEND_API_TOKEN=
