NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Server-to-server token for the Express backend (delivery routes).
# Must match BACKEND_API_TOKEN in apps/api/.env. Server-only — no NEXT_PUBLIC_ prefix.
BACKEND_API_TOKEN=

# Service-role key (Supabase dashboard → Settings → API → service_role).
# Server-only — NEVER prefix with NEXT_PUBLIC_. Used by /api/lead to create
# member/lead rows (anon cannot write to `member`). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
