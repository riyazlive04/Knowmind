# Prisma / Neon Postgres (same values as packages/db/.env).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth.js (NextAuth v5) session signing secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-generated-secret-here"

# Express backend base URL (public — used by the browser).
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Server-to-server token for the Express backend (delivery routes).
# Must match BACKEND_API_TOKEN in apps/api/.env. Server-only — no NEXT_PUBLIC_ prefix.
BACKEND_API_TOKEN=
